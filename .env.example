# Copy to .env and edit BEFORE `docker compose up`.
# In production (FLASK_DEBUG=false) the backend REFUSES TO START until
# JWT_SECRET and BOOTSTRAP_ADMIN_PASS are set to strong, non-default values.

# ── Auth (CHANGE THESE — required) ─────────────────────
# Generate JWT_SECRET:  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=

# ── MongoDB (auth enabled — required) ──────────────────
# Compose builds MONGO_URI from these; Mongo is not published externally.
MONGO_USER=wlcmon
MONGO_PASS=
MONGO_DB=c9800_monitor
COLLECT_INTERVAL=30

# ── Web / CORS ─────────────────────────────────────────
# Set to the app's real URL in production (avoid "*").
CORS_ORIGINS=https://wlc.example.com:8443

# ── WLC connection ─────────────────────────────────────
# WLC_VENDOR: cisco (Catalyst 9800) or ruckus (SmartZone/vSZ, port 8443)
WLC_VENDOR=cisco
WLC_HOST=192.168.100.16
WLC_PORT=443
WLC_USERNAME=admin
WLC_PASSWORD=
WLC_VERIFY_SSL=false

# Ruckus only: SmartZone API version segment (e.g. v11_0 for SmartZone 6.1)
# RUCKUS_API_VERSION=v11_0

# ── App ────────────────────────────────────────────────
DEMO_MODE=false

# ── License ────────────────────────────────────────────
# The app boots but stays LOCKED until an admin uploads a license on the in-app
# Licensing page (stored in MongoDB). LICENSE_KEY below is OPTIONAL — if set, it
# auto-activates that token on first boot (handy for automated installs).
# LICENSE_KEY=
# Set false to disable the license lock entirely (internal use only).
# LICENSE_ENFORCE=true

# ── Hardening (optional) ───────────────────────────────
# Key for encrypting the WLC password at rest. If unset, derived from JWT_SECRET
# (fine for single-host installs). Set a dedicated value if you rotate JWT_SECRET.
# SECRET_ENCRYPTION_KEY=
# Rate-limit storage. Default in-memory suits the single-worker deployment;
# use redis://host:6379 if you scale to multiple workers.
# RATELIMIT_STORAGE=memory://