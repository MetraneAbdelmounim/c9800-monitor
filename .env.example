# Copy to .env and edit before `docker compose up`.

# ── Auth (CHANGE THESE) ────────────────────────────────
JWT_SECRET=please-change-to-a-long-random-string
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=change-me-on-first-login

# ── Database ───────────────────────────────────────────
# MONGO_URI is set by docker-compose to the internal mongo service.
MONGO_DB=c9800_monitor
COLLECT_INTERVAL=30

# ── Catalyst 9800 WLC connection ───────────────────────
WLC_HOST=192.168.100.16
WLC_PORT=443
WLC_USERNAME=admin
WLC_PASSWORD=change-me
WLC_VERIFY_SSL=false

# ── App ────────────────────────────────────────────────
DEMO_MODE=false
