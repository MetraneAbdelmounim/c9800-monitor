# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ── WLC Connection ─────────────────────────────────────
WLC_HOST=192.168.100.16
WLC_PORT=443
WLC_USERNAME=admin
WLC_PASSWORD=P@ss2025
WLC_VERIFY_SSL=false

# ── Flask Server ───────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── Demo Mode ──────────────────────────────────────────
DEMO_MODE=true
# ── MongoDB ────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=c9800_monitor
COLLECT_INTERVAL=30

# ── JWT Auth ───────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=8

# Bootstrap admin (created on first startup if users collection is empty)
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=admin
